# ============================================================
# Production environment for the Docker stack.
#
#   cp .env.production.example .env.production
#   # then edit the values below (this file is gitignored)
#
# Consumed by:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml \
#     --env-file .env.production up -d --build
# ============================================================

# ---- Public URL (your domain, behind the TLS reverse proxy) ----
APP_URL=https://your-domain.com
WEBAPP_URL=https://your-domain.com

# ---- App key (REQUIRED) ----
# Generate once with:
#   docker compose run --rm app php artisan key:generate --show
APP_KEY=

# ---- Database credentials (REQUIRED) ----
# NOTE: these are baked into the DB on the FIRST start only (fresh volume).
# Pick strong values before the very first `up`.
DB_DATABASE=u2304932_car_booking
DB_USERNAME=u2304932_car_booking
DB_PASSWORD=change-me-to-a-strong-password
DB_ROOT_PASSWORD=change-me-to-a-different-strong-password

# ---- Telegram bot (optional; leave blank to disable) ----
TELEGRAM_BOT_TOKEN=

# ---- Host port bindings ----
# The web/db ports bind to 127.0.0.1 only; your reverse proxy connects to WEB_PORT.
WEB_PORT=8090
WEB_BIND=127.0.0.1
DB_PORT_HOST=3307
DB_BIND=127.0.0.1
